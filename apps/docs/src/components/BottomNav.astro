---
import { isActive, navItems } from "../config/nav";
import NavMorph from "./NavMorph.astro";

interface Props {
  references?: { label: string; href: string }[];
}

const { references = [] } = Astro.props;

const pathname = Astro.url.pathname;

const foundIndex = navItems.findIndex((item) => isActive(pathname, item.href));
const activeIndex = foundIndex >= 0 ? foundIndex : 0;
const activeItem = navItems[activeIndex];
const pages = navItems.filter((_, index) => index !== activeIndex);

const hasReferences = references.length > 0;
---

<nav class="bottom-nav" aria-label="Pages">
  {
    hasReferences ? (
      <NavMorph
        activeItem={activeItem}
        references={references}
        pages={pages}
        trigger="touch"
      />
    ) : (
      <ul class="links" role="list">
        {navItems.map((item) => (
          <li>
            <a
              class:list={["link", { active: isActive(pathname, item.href) }]}
              href={item.href}
              aria-current={isActive(pathname, item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</nav>

<style>
  /* desktop hides it entirely; the top navbar owns navigation there. */
  .bottom-nav {
    display: none;
  }

  @media (max-width: 768px) {
    .bottom-nav {
      display: flex;
      align-items: center;
      position: fixed;
      left: 50%;
      bottom: calc(0.85rem + env(safe-area-inset-bottom));
      transform: translateX(-50%);
      max-width: calc(100vw - 1rem);
      z-index: 50;

      /* mobile sizing for the shared gooey morph */
      --morph-height: 2.6rem;
      --morph-gap: 0.6rem;
    }
  }

  /* ---- plain nav (pages without in-page references) -------------------- */
  .links {
    display: flex;
    align-items: center;
    height: 2.6rem;
    margin: 0;
    padding: 0 0.4rem;
    gap: 0.05rem;
    list-style: none;
    border-radius: var(--radius-pill);
    background: var(--ink);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .links::-webkit-scrollbar {
    display: none;
  }

  .link {
    display: inline-flex;
    align-items: center;
    padding: 0 0.6rem;
    height: 1.9rem;
    border-radius: var(--radius-pill);
    color: var(--ink-fg);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.65;
    transition: opacity var(--ease);
  }
  .link:hover,
  .link:focus-visible {
    opacity: 1;
  }
  .link.active {
    opacity: 1;
  }
</style>
