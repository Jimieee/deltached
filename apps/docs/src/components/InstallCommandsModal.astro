---
import Icon from "./Icon.astro";
import Modal from "./Modal.astro";

const modalId = "install-commands-modal";

const commands = [
  "npm install deltached",
  "pnpm add deltached",
  "yarn add deltached",
  "bun add deltached",
];
---

<button class="trigger" type="button" data-modal-open={modalId}>
  view install commands
</button>

<Modal id={modalId} title="Install deltached">
  <div class="commands" role="list">
    {
      commands.map((command) => (
        <div class="command" role="listitem">
          <span class="prompt" aria-hidden="true">
            $
          </span>
          <code>{command}</code>
          <button
            class="copy"
            type="button"
            data-copy={command}
            aria-label={`Copy ${command}`}
          >
            <span class="copy-icon" data-copy-icon="copy">
              <Icon name="copy" size={18} />
            </span>

            <span class="copy-icon copy-icon--check" data-copy-icon="check">
              <Icon name="check" size={18} />
            </span>
          </button>
        </div>
      ))
    }
  </div>
</Modal>

<style>
  .trigger {
    margin-top: clamp(2rem, 6vh, 4rem);
    min-width: 12rem;
    height: 2.75rem;
    padding-inline: 1.4rem;

    border: 0;
    border-radius: var(--radius-pill);

    background: var(--surface);
    color: var(--fg);

    font: inherit;
    cursor: pointer;
    transition:
      transform var(--ease),
      opacity var(--ease);
  }

  /* 
  deltached marks the source while it drives the morph handoff (toggling
  opacity/visibility); killing the transition then keeps the button from
  fading on its own as it disappears/reappears. 
  */
  .trigger[data-deltached-morphing] {
    transition: none;
  }

  .trigger:hover,
  .trigger:focus-visible {
    opacity: 0.9;
  }

  .trigger:active {
    transform: scale(0.98);
  }

  .commands {
    display: grid;
    gap: 0.5rem;
  }

  .command {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) 2.85rem;
    align-items: center;
    min-height: 2.75rem;
    overflow: hidden;

    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .prompt {
    padding-left: 0.85rem;
    color: var(--muted);
    font-family: "Geist Mono Variable", ui-monospace, monospace;
    font-size: 0.9rem;
  }

  code {
    min-width: 0;
    overflow: hidden;
    padding: 0 0.7rem;
    color: var(--fg-soft);
    font-size: 0.9rem;
    line-height: 1;
    text-align: left;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .copy {
    position: relative;
    isolation: isolate;

    width: 2.85rem;
    height: 100%;

    border: 0;
    border-left: 1px solid var(--border);

    background: var(--surface);
    color: var(--muted);

    cursor: pointer;
    overflow: hidden;

    transition:
      color var(--ease),
      background var(--ease),
      transform var(--ease);
  }

  .copy-icon {
    position: absolute;
    inset: 0;

    display: grid;
    place-items: center;

    pointer-events: none;
    will-change: opacity, transform, filter;
  }

  .copy-icon--check {
    opacity: 0;
    visibility: hidden;
    transform: scale(0.72);
    filter: blur(6px);
  }

  .copy:hover,
  .copy:focus-visible {
    color: var(--fg);
    background: var(--surface-hover);
  }

  .copy:active {
    transform: scale(0.96);
  }

  .copy[data-copied="true"] {
    color: var(--fg);
    background: var(--surface-success);
  }
</style>
