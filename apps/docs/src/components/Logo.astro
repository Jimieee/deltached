---
interface Props {
  size?: number | string;
  title?: string;
  class?: string;
  color?: string;
}

const {
  size = 64,
  title,
  class: className,
  color = "currentColor",
  ...attributes
} = Astro.props;
---

<svg
  viewBox="0 0 1024 1024"
  width={size}
  height={size}
  class={className}
  role={title ? "img" : undefined}
  aria-label={title}
  aria-hidden={title ? undefined : "true"}
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
  {...attributes}
>
  {title && <title>{title}</title>}

  <path
    fill={color}
    fill-rule="evenodd"
    clip-rule="evenodd"
    d="M512 80.008a56.006 56.006 0 0 0-50.557 31.908l-343 720A56.006 56.006 0 0 0 169 912h391a56 56 0 0 0 0-112H257.707L512 266.209 766.293 800H722a56 56 0 0 0 0 112h133a56.006 56.006 0 0 0 50.557-80.084l-343-720A56.006 56.006 0 0 0 512 80.008Z"
  ></path>
</svg>
