---
import Icon from "./Icon.astro";

interface Props {
  id: string;
  title?: string;
  description?: string;
  class?: string;
}

const {
  id,
  title,
  description,
  class: className,
} = Astro.props;

const titleId = title ? `${id}-title` : undefined;
const descriptionId = description ? `${id}-description` : undefined;
---

<dialog
  id={id}
  class:list={["modal", className]}
  aria-labelledby={titleId}
  aria-describedby={descriptionId}
>
  <div class="shell">
    <form class="close-form" method="dialog">
      <button class="close" type="submit" aria-label="Close modal">
        <Icon name="x" size={18} />
      </button>
    </form>

    {
      title && (
        <header class="header">
          <h2 id={titleId}>{title}</h2>
          {description && <p id={descriptionId}>{description}</p>}
        </header>
      )
    }

    <div class="body">
      <slot />
    </div>
  </div>
</dialog>

<style>
  .modal {
    width: min(100% - 2rem, 28rem);
    max-height: min(36rem, calc(100dvh - 2rem));
    margin: auto;
    padding: 0;
    overflow: auto;

    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--surface);
    color: var(--fg);
    text-align: left;
    box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.16);
  }

  .modal::backdrop {
    background: rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(0.2rem);
  }

  .modal:not([open]) {
    display: none;
  }

  .shell {
    position: relative;
    padding: 1.25rem;
  }

  .close-form {
    margin: 0;
  }

  .close {
    position: absolute;
    top: 1rem;
    right: 1rem;

    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;

    border: 0;
    border-radius: 50%;
    background: var(--surface);
    color: var(--fg);
    cursor: pointer;
    transition:
      background var(--ease),
      transform var(--ease);
  }

  .close:hover,
  .close:focus-visible {
    background: #f5f5f5;
  }

  .close:active {
    transform: scale(0.96);
  }

  .header {
    padding-right: 2.5rem;
  }

  h2 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.15;
    font-weight: 650;
    letter-spacing: 0;
  }

  p {
    max-width: 28rem;
    margin: 0.45rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .body {
    margin-top: 1rem;
  }

  @media (max-width: 520px) {
    .modal {
      width: min(100% - 1rem, 34rem);
      border-radius: 0.9rem;
    }

    .shell {
      padding: 1rem;
    }

    .close {
      top: 0.75rem;
      right: 0.75rem;
      width: 2rem;
      height: 2rem;
    }
  }
</style>
