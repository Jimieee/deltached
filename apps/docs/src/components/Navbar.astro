---
import { isActive, navItems, NPM, REPO } from "../config/nav";
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import NavMorph from "./NavMorph.astro";

interface Props {
  /** In-page section references; with them the center shows the gooey
   *  active-chip + sections morph, otherwise a plain pill of all pages. */
  references?: { label: string; href: string }[];
}

const { references = [] } = Astro.props;

const pathname = Astro.url.pathname;

const foundIndex = navItems.findIndex((item) => isActive(pathname, item.href));
const activeIndex = foundIndex >= 0 ? foundIndex : 0;
const activeItem = navItems[activeIndex];
const pages = navItems.filter((_, index) => index !== activeIndex);

const hasReferences = references.length > 0;
---

<nav
  class="nav"
  aria-label="Primary"
  data-route-nav="desktop"
  data-nav-has-references={String(hasReferences)}
>
  <a
    class="circle"
    href="/"
    aria-label="deltached — home"
  >
    <Logo size={32} />
  </a>

  <div class="nav__center">
    {
      hasReferences ? (
        <div class="nav__theme">
          <NavMorph
            activeItem={activeItem}
            references={references}
            pages={pages}
          />
        </div>
      ) : (
        <ul class="links" role="list" data-nav-plain>
          {navItems.map((item) => (
            <li>
              <a
                class:list={["link", { active: isActive(pathname, item.href) }]}
                href={item.href}
                aria-current={isActive(pathname, item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>

  <div class="external">
    <a
      class="circle"
      href={REPO}
      target="_blank"
      rel="noreferrer"
      aria-label="GitHub"
    >
      <Icon name="brand-github" size={32} />
    </a>
    <a
      class="circle"
      href={NPM}
      target="_blank"
      rel="noreferrer"
      aria-label="npm"
    >
      <Icon name="brand-npm" size={32} />
    </a>
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem;

    position: sticky;
    top: 0;
    z-index: 100;
  }

  .circle {
    flex: 0 0 auto;
    width: var(--nav-size);
    height: var(--nav-size);
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--ink);
    color: var(--ink-fg);
    text-decoration: none;
    transition:
      transform var(--ease),
      opacity var(--ease);
  }

  .circle:hover,
  .circle:focus-visible {
    opacity: 0.9;
  }

  .nav__center {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  /* desktop sizing for the shared gooey morph + references pill */
  .nav__theme {
    display: contents;

    --morph-height: var(--nav-size);
    --morph-gap: 0.9rem;

    --refs-height: var(--nav-size);
    --refs-arrow: 2.4rem;
    --refs-track-max: min(38vw, 24rem);
    --refs-font: 1.05rem;
    --refs-fade: 1.2rem;
    --refs-pad: 0.85rem;
    --refs-link-pad: 0.95rem;
    --refs-gap: 0.35rem;
  }

  /* ---- plain nav (pages without in-page references) -------------------- */
  .links {
    display: flex;
    align-items: center;
    height: var(--nav-size);
    margin: 0;
    padding: 0 0.65rem;
    gap: 0.1rem;
    list-style: none;
    border-radius: var(--radius-pill);
    background: var(--ink);
  }

  .link {
    display: block;
    padding: 0.5rem 0.95rem;
    border-radius: var(--radius-pill);
    color: var(--ink-fg);
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 500;
    opacity: 0.65;
    transition: opacity var(--ease);
  }
  .link:hover,
  .link:focus-visible {
    opacity: 1;
  }
  /* current page: brighter only — same shape as the rest, no box. */
  .link.active {
    opacity: 1;
  }

  .external {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* mobile: header role only — logo left, externals right; pages move to the
     bottom nav, so the center area is hidden. */
  @media (max-width: 768px) {
    .nav {
      justify-content: space-between;
      gap: 0.5rem;
      padding: 1rem;
    }
    .nav__center {
      display: none;
    }
    .circle {
      width: var(--nav-size-sm);
      height: var(--nav-size-sm);
    }
    .external {
      gap: 0.5rem;
    }
  }
</style>
