---
import { isActive, navItems, NPM, REPO } from "../config/nav";
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";

const pathname = Astro.url.pathname;
---

<nav class="nav" aria-label="Primary">
  <a class="circle" href="/" aria-label="deltached — home">
    <Logo size={32} />
  </a>

  <!-- text links: desktop only (mobile uses the bottom nav) -->
  <ul class="links" role="list">
    {
      navItems.map((l) => (
        <li>
          <a
            class:list={["link", { active: isActive(pathname, l.href) }]}
            href={l.href}
            aria-current={isActive(pathname, l.href) ? "page" : undefined}
          >
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="external">
    <a
      class="circle"
      href={REPO}
      target="_blank"
      rel="noreferrer"
      aria-label="GitHub"
    >
      <Icon name="brand-github" size={32} />
    </a>
    <a
      class="circle"
      href={NPM}
      target="_blank"
      rel="noreferrer"
      aria-label="npm"
    >
      <Icon name="brand-npm" size={32} />
    </a>
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem;

    position: sticky;
    top: 0;
    z-index: 100;
  }

  .circle {
    flex: 0 0 auto;
    width: var(--nav-size);
    height: var(--nav-size);
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--ink);
    color: var(--ink-fg);
    text-decoration: none;
    transition:
      transform var(--ease),
      opacity var(--ease);
  }

  .circle:hover,
  .circle:focus-visible {
    opacity: 0.9;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    height: var(--nav-size);
    margin: 0;
    padding: 0 0.75rem;
    list-style: none;
    border-radius: var(--radius-pill);
    background: var(--ink);
  }

  .link {
    display: block;
    padding: 0.5rem 0.95rem;
    border-radius: var(--radius-pill);
    color: var(--ink-fg);
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 500;
    opacity: 0.75;
    transition:
      opacity var(--ease),
      background var(--ease);
  }
  .link:hover,
  .link:focus-visible {
    opacity: 1;
  }
  .link.active {
    opacity: 1;
    background: var(--hover-tint);
  }

  .external {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* mobile: header role only — logo left, externals right; pages move to the
     bottom nav, so the text links are hidden. */
  @media (max-width: 768px) {
    .nav {
      justify-content: space-between;
      gap: 0.5rem;
      padding: 1rem;
    }
    .links {
      display: none;
    }
    .circle {
      width: var(--nav-size-sm);
      height: var(--nav-size-sm);
    }
    .external {
      gap: 0.5rem;
    }
  }
</style>
