---
/**
 * Minimalist content card that doubles as a deltached morph source: the whole
 * card is the `[data-modal-open]` trigger, so clicking it carries the card box
 * into its matching <Modal> and back. No example-specific JS — modal.ts wires
 * every trigger on the page.
 *
 * Two layouts:
 *  - "split" (default): media panel + text, dark CTA pill (matches the brief).
 *  - "cover": full-bleed image with the title overlaid at the bottom.
 *
 * `accent` lets each section tint the CTA/overlay so the gallery shows variety
 * without forking the component.
 */
interface Props {
  modalId: string;
  image: string;
  title: string;
  eyebrow?: string;
  cta?: string;
  variant?: "split" | "cover";
  accent?: string;
  /**
   * `data-deltached-id` for the media / title. When the matching <Modal>
   * renders an element with the same id, deltached flies that child between
   * the card and the dialog (image + text persist adapters) instead of just
   * crossfading it.
   */
  mediaId?: string;
  titleId?: string;
  /**
   * Resting placement for the morph (forwarded to deltached via
   * `data-modal-placement`). The origin family (`"origin"`, `"origin-top"`,
   * `"origin-bottom"`, `"origin-left"`, `"origin-right"`, `"origin-auto"`)
   * opens the panel anchored to this card; omit for the default centered behavior.
   */
  placement?:
    | "center"
    | "origin"
    | "origin-top"
    | "origin-bottom"
    | "origin-left"
    | "origin-right"
    | "origin-auto";
}

const {
  modalId,
  image,
  title,
  eyebrow,
  cta = "Learn more",
  variant = "split",
  accent,
  mediaId,
  titleId,
  placement,
} = Astro.props;

const style = accent ? `--card-accent: ${accent}` : undefined;
---

<button
  class:list={["card", `card--${variant}`]}
  type="button"
  data-modal-open={modalId}
  data-modal-placement={placement && placement !== "center" ? placement : undefined}
  style={style}
  aria-label={`Open ${title}`}
>
  <span
    class="card__media"
    style={`background-image: url("${image}")`}
    data-deltached-id={mediaId}
    aria-hidden="true"></span>

  <span class="card__body">
    {eyebrow && <span class="card__eyebrow">{eyebrow}</span>}
    <span class="card__title" data-deltached-id={titleId}>{title}</span>
    {cta && <span class="card__cta">{cta}</span>}
  </span>
</button>

<style>
  .card {
    --card-accent: var(--ink);

    position: relative;
    display: grid;
    overflow: hidden;
    width: 100%;

    margin: 0;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--fg);
    box-shadow: var(--shadow-sm);

    text-align: left;
    cursor: pointer;
    font: inherit;

    transition:
      transform var(--ease),
      box-shadow var(--ease);
  }

  /* deltached owns visibility during the handoff — drop transitions so the
     card doesn't fade/scale on its own as it disappears and reappears. */
  .card[data-deltached-morphing] {
    transition: none;
  }

  .card:active {
    transform: translateY(0) scale(0.99);
  }

  .card__media {
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    background-color: var(--surface-active);
  }

  /* ---- split ----------------------------------------------------------- */
  .card--split {
    grid-template-columns: 42% 1fr;
    align-items: stretch;
    min-height: 9rem;
  }

  .card--split .card__media {
    min-height: 100%;
  }

  .card--split .card__body {
    display: grid;
    align-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1.1rem;
  }

  .card__eyebrow {
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card__title {
    font-size: 1.05rem;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .card__cta {
    justify-self: start;

    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-pill);
    background: var(--card-accent);
    color: var(--ink-fg);

    font-size: 0.8rem;
    font-weight: 550;
  }

  /* ---- cover ----------------------------------------------------------- */
  .card--cover {
    aspect-ratio: 3 / 2;
  }

  .card--cover .card__media {
    position: absolute;
    inset: 0;
  }

  .card--cover .card__body {
    position: relative;
    align-self: end;

    display: grid;
    gap: 0.2rem;
    width: 100%;
    padding: 2.5rem 1.1rem 1rem;

    color: var(--ink-fg);
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--card-accent) 88%, transparent),
      transparent
    );
  }

  .card--cover .card__eyebrow {
    color: rgba(255, 255, 255, 0.75);
  }

  .card--cover .card__title {
    font-size: 1.1rem;
  }

  .card--cover .card__cta {
    display: none;
  }
</style>
