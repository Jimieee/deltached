---
/**
 * Presentational shell for one examples section: an anchored heading + a
 * responsive grid. It knows nothing about data — sections feed it cards
 * through the default slot.
 */
interface Props {
  id: string;
  title: string;
  description?: string;
}

const { id, title, description } = Astro.props;
---

<section class="section" id={id} aria-labelledby={`${id}-title`}>
  <header class="section__head">
    <h2 id={`${id}-title`}>{title}</h2>
    {description && <p>{description}</p>}
  </header>

  <div class="section__grid">
    <slot />
  </div>
</section>

<style>
  .section {
    width: 100%;
  }

  .section__head {
    max-width: 40rem;
    margin-bottom: 1.75rem;
  }

  h2 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 640;
    letter-spacing: -0.022em;
    line-height: 1.1;
  }

  p {
    margin: 0.5rem 0 0;
    color: var(--ex-label-2, var(--muted));
    font-size: 0.975rem;
    line-height: 1.5;
    letter-spacing: -0.006em;
  }

  .section__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1.25rem;
  }
</style>
