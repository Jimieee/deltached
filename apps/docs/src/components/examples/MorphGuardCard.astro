---
/**
 * Didactic card for the `[data-deltached-morphing]` comparison.
 *
 * While deltached hands the trigger off to (and back from) the morph surface,
 * it sets `data-deltached-morphing` on the trigger and drives its
 * opacity/visibility. A consumer transition on those properties (this card has
 * one, like most real buttons) would animate that handoff — the trigger fades
 * back in on its own after the dialog closes.
 *
 * `guarded` adds the one-line opt-out `[data-deltached-morphing]{transition:none}`.
 * Render both side by side and the difference is obvious: the unguarded card
 * flickers on close, the guarded one snaps.
 */
interface Props {
  modalId: string;
  image: string;
  label: string;
  guarded: boolean;
  mediaId?: string;
  accent?: string;
}

const { modalId, image, label, guarded, mediaId, accent } = Astro.props;

const style = accent ? `--card-accent: ${accent}` : undefined;
---

<button
  class:list={["guard", { "guard--on": guarded }]}
  type="button"
  data-modal-open={modalId}
  style={style}
>
  <span
    class="guard__media"
    style={`background-image: url("${image}")`}
    data-deltached-id={mediaId}
    aria-hidden="true"></span>

  <span class="guard__body">
    <span class="guard__tag">{guarded ? "with guard" : "without guard"}</span>
    <span class="guard__label">{label}</span>
  </span>
</button>

<style>
  .guard {
    --card-accent: var(--ink);

    display: grid;
    grid-template-columns: 40% 1fr;
    align-items: stretch;
    overflow: hidden;

    margin: 0;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--fg);
    box-shadow: var(--shadow-sm);

    text-align: left;
    cursor: pointer;
    font: inherit;

    /* The whole point of the demo: a transition on the very channels deltached
       drives during the handoff (opacity/transform). */
    transition:
      transform 0.4s ease,
      opacity 0.4s ease,
      box-shadow 0.4s ease;
  }

  /* Only the guarded card opts out, so its handoff is suppressed. */
  .guard--on[data-deltached-morphing] {
    transition: none;
  }

  .guard:hover,
  .guard:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .guard__media {
    min-height: 8rem;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    background-color: var(--surface-active);
  }

  .guard__body {
    display: grid;
    align-content: center;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
  }

  .guard__tag {
    justify-self: start;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
    background: var(--card-accent);
    color: var(--ink-fg);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .guard__label {
    font-size: 0.95rem;
    font-weight: 550;
    color: var(--muted);
  }
</style>
