---
/**
 * Avatar-centric card for the Profiles section. Same morph contract as
 * ExampleCard (the whole card is a `[data-modal-open]` trigger) but a softer,
 * centered layout so the gallery reads as visibly different examples.
 */
interface Props {
  modalId: string;
  name: string;
  avatar: string;
  subtitle?: string;
  accent?: string;
  /**
   * `data-deltached-id` for the avatar / name. With the same ids on the
   * matching <Modal>, both children fly from the compact card into the
   * expanded panel at once (image + text persist) — the clearest demo of
   * multiple nested shared elements travelling together.
   */
  avatarId?: string;
  nameId?: string;
}

const { modalId, name, avatar, subtitle, accent, avatarId, nameId } =
  Astro.props;

const style = accent ? `--card-accent: ${accent}` : undefined;
---

<button
  class="profile"
  type="button"
  data-modal-open={modalId}
  style={style}
  aria-label={`Open ${name}'s profile`}
>
  <img
    class="profile__avatar"
    src={avatar}
    alt=""
    width="72"
    height="72"
    data-deltached-id={avatarId}
  />

  <span class="profile__name" data-deltached-id={nameId}>{name}</span>
  {subtitle && <span class="profile__sub">{subtitle}</span>}
</button>

<style>
  .profile {
    --card-accent: var(--ink);

    display: grid;
    justify-items: center;
    gap: 0.35rem;

    margin: 0;
    padding: 1.5rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--card-accent);
    color: var(--fg);
    box-shadow: var(--shadow-sm);

    text-align: center;
    cursor: pointer;
    font: inherit;

    transition:
      transform var(--ease),
      box-shadow var(--ease);
  }

  .profile[data-deltached-morphing] {
    transition: none;
  }

  .profile:active {
    transform: translateY(0) scale(0.99);
  }

  .profile__avatar {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: var(--radius-pill);
    border: 2px solid var(--surface);
    box-shadow: 0 0 0 1px var(--border);
    object-fit: cover;
  }

  .profile__name {
    margin-top: 0.4rem;
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: -0.01em;
  }

  .profile__sub {
    color: var(--muted);
    font-size: 0.85rem;
  }
</style>
