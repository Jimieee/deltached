---
import ExampleCard from "../../components/examples/ExampleCard.astro";
import ExampleSection from "../../components/examples/ExampleSection.astro";
import Modal from "../../components/Modal.astro";
import { getProducts } from "../../data/products";

interface Props {
  id: string;
}

const { id } = Astro.props;

const products = await getProducts();
const accent = "#1f6feb";

const priceFormatter = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
});

// Showcase every origin-family placement: each card opens with a different
// growth direction so the gallery demonstrates the whole set at once.
const placements = [
  "origin",
  "origin-bottom",
  "origin-top",
  "origin-right",
  "origin-left",
  "origin-auto",
] as const;

const placementCta: Record<(typeof placements)[number], string> = {
  origin: "Grows from center",
  "origin-bottom": "Grows down ↓",
  "origin-top": "Grows up ↑",
  "origin-right": "Grows right →",
  "origin-left": "Grows left ←",
  "origin-auto": "Auto ↕ (flips up/down)",
};
---

<ExampleSection
  id={id}
  title="Modals"
  description="Surface morph with persisted children, opened with the origin placement family: the dialog grows out of the card you click — from its center, toward a side (down / up / right / left), or auto (a vertical dropdown that flips up/down toward the room, live as you resize) — and stays anchored there, clamped to the viewport and re-clamped on resize. The thumbnail and the title, tagged with the same data-deltached-id on both sides, fly into their new place instead of crossfading. Each card below is labelled with the variant it uses."
>
  {
    products.map((product, i) => {
      const placement = placements[i % placements.length];
      return (
        <ExampleCard
          modalId={`ex-modal-${product.id}`}
          image={product.image}
          eyebrow={product.category}
          title={product.title}
          cta={placementCta[placement]}
          accent={accent}
          mediaId={`product-media-${product.id}`}
          titleId={`product-title-${product.id}`}
          placement={placement}
        />
      );
    })
  }
</ExampleSection>

{
  products.map((product) => (
    <Modal id={`ex-modal-${product.id}`} class="ex-detail" ariaLabel={product.title}>
      <img
        class="ex-detail__media"
        src={product.image}
        alt={product.title}
        data-deltached-id={`product-media-${product.id}`}
      />
      <h2 class="ex-detail__title" data-deltached-id={`product-title-${product.id}`}>
        {product.title}
      </h2>
      <p class="ex-detail__price">{priceFormatter.format(product.price)}</p>
      <p class="ex-detail__text">{product.description}</p>
    </Modal>
  ))
}

<style is:global>
  .ex-detail__media {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: var(--radius-sm);
    background: var(--surface-active);
  }

  .ex-detail__title {
    margin: 1rem 0 0;
    font-size: 1.25rem;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .ex-detail__price {
    margin: 0.5rem 0 0;
    font-size: 1.1rem;
    font-weight: 650;
    color: var(--accent, #1f6feb);
  }

  .ex-detail__text {
    margin: 0.5rem 0 0;
    color: var(--fg-soft);
    font-size: 0.95rem;
    line-height: 1.55;
  }
</style>
