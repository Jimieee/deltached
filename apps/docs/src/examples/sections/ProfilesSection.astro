---
import ExampleSection from "../../components/examples/ExampleSection.astro";
import ProfileCard from "../../components/examples/ProfileCard.astro";
import Modal from "../../components/Modal.astro";
import { getProfiles } from "../../data/profiles";

const profiles = await getProfiles();
const accent = "#be98ff";
---

<ExampleSection
  id="profiles"
  title="Profiles"
  description="Multiple persisted children at once. Click a person and both the avatar (image adapter) and the name (text adapter) travel from the compact card into the expanded panel together — the avatar grows along its path, the name re-sizes to the heading. Everything else is the surface morph."
>
  {
    profiles.map((profile) => (
      <ProfileCard
        modalId={`ex-profile-${profile.id}`}
        name={profile.name}
        avatar={profile.avatar}
        subtitle={profile.location}
        accent={accent}
        avatarId={`profile-avatar-${profile.id}`}
        nameId={`profile-name-${profile.id}`}
      />
    ))
  }
</ExampleSection>

{
  profiles.map((profile) => (
    <Modal
      id={`ex-profile-${profile.id}`}
      class="ex-profile"
      ariaLabel={profile.name}
    >
      <div class="ex-profile__head">
        <img
          class="ex-profile__avatar"
          src={profile.avatar}
          alt=""
          width="112"
          height="112"
          data-deltached-id={`profile-avatar-${profile.id}`}
        />
        <h2
          class="ex-profile__name"
          data-deltached-id={`profile-name-${profile.id}`}
        >
          {profile.name}
        </h2>
        <p class="ex-profile__location">{profile.location}</p>
      </div>

      <a class="ex-profile__email" href={`mailto:${profile.email}`}>
        {profile.email}
      </a>
    </Modal>
  ))
}

<style is:global>
  .ex-profile__head {
    display: grid;
    justify-items: center;
    gap: 0.4rem;
  }

  .ex-profile__avatar {
    width: 7rem;
    height: 7rem;
    border-radius: var(--radius-pill);
    object-fit: cover;
    box-shadow: 0 0 0 1px var(--border);
  }

  .ex-profile__name {
    margin: 0.5rem 0 0;
    font-size: 1.35rem;
    font-weight: 650;
    letter-spacing: -0.01em;
  }

  .ex-profile__location {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .ex-profile__email {
    display: block;
    margin-top: 1rem;
    padding: 0.65rem 1rem;

    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--fg);

    font-size: 0.9rem;
    text-align: center;
    text-decoration: none;
    transition: background var(--ease);
  }

  .ex-profile__email:hover {
    background: var(--surface-hover);
  }
</style>
