---
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "deltached",
  description = "Deltached transitions for the web.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <slot />

    <style is:global>
      :root {
        /* minimalist black-on-white palette */
        --bg: #ffffff;
        --fg: #171717;
        --muted: #6b7280;
        --ink: #171717; /* the dark pills / circles */
        --ink-fg: #ffffff;
        --surface: #ffffff;
        --border: #e6e6e6;

        font-family:
          "Geist Variable", system-ui, -apple-system, sans-serif;
        font-synthesis: none;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100dvh;
        background: var(--bg);
        color: var(--fg);
        font-family: inherit;
      }

      code,
      pre,
      kbd {
        font-family: "Geist Mono Variable", ui-monospace, monospace;
      }
    </style>
  </body>
</html>
