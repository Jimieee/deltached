---
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import BottomNav from "../components/BottomNav.astro";
import GooFilter from "../components/GooFilter.astro";
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
  /** Social-share image. Path is resolved against the site origin + base. */
  image?: string;
  /** In-page section references for the navbar (pages with anchors). */
  references?: { label: string; href: string }[];
}

const {
  title = "deltached",
  description = "An interruptible, in-page shared-element morph controller for the web.",
  image,
  references = [],
} = Astro.props;

const SITE_NAME = "deltached";
// Normalize so it always ends in "/" ("/deltached/" on Pages, "/" locally),
// otherwise `${BASE}favicon.svg` collapses to "/deltachedfavicon.svg".
const rawBase = import.meta.env.BASE_URL;
const BASE = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

// Absolute URLs — required for canonical links and Open Graph/Twitter cards.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image ?? `${BASE}og-image.png`, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Icons -->
    <link rel="icon" href={`${BASE}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${BASE}favicon-32.png`} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={`${BASE}apple-touch-icon.png`} />
    <link rel="manifest" href={`${BASE}site.webmanifest`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE_NAME} — ${description}`} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <ClientRouter />
  </head>
  <body>
    <GooFilter />
    <Navbar references={references} />
    <BottomNav references={references} />
    <slot />

    <div class="scrollbar" data-scrollbar aria-hidden="true">
      <span class="scrollbar__thumb" data-scrollbar-thumb></span>
    </div>

    <script src="../scripts/main.ts"></script>
  </body>
</html>
