---
import Base from "../layouts/Base.astro";
---

<Base title="deltached — changelog">
  <main class="page">
    <h1>Changelog</h1>
    <p>Release notes will appear here.</p>
  </main>

  <style>
    .page {
      display: grid;
      gap: 0.5rem;
      justify-items: center;
      text-align: center;
      padding: 5rem 2rem;
    }
    h1 {
      margin: 0;
      font-size: 2rem;
      font-weight: 600;
      letter-spacing: -0.03em;
    }
    p {
      margin: 0;
      color: var(--muted);
    }
  </style>
</Base>
