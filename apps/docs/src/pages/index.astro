---
import Base from "../layouts/Base.astro";
import InstallCommandsModal from "../components/InstallCommandsModal.astro";
---

<Base title="Deltached.">
  <main class="hero center">
    <section class="panel">
      <div class="content">
        <h1 class="events-none" data-animate="font-weight">Deltached.</h1>

        <p class="events-none">
          An interruptible in-page shared element controller. GSAP-powered box
          morphing, geometric pinning, and child-layer persistence — layout
          continuity under any interaction.
        </p>

        <InstallCommandsModal />
      </div>
    </section>
  </main>
</Base>

<style>
  .center {
    display: grid;
  }

  .hero {
    width: 100%;
    min-height: calc(100dvh - 112px);
    min-width: 0;

    padding: 0 1rem 1rem;
    overflow: hidden;
  }

  .panel {
    width: 100%;
    min-height: 100%;
    min-width: 0;

    display: grid;
    place-items: center;

    padding: clamp(1.5rem, 5vw, 5rem);

    overflow: hidden;
    background: var(--fg);
    color: var(--ink-fg);
    border-radius: 2rem;
    box-sizing: border-box;
  }

  .content {
    width: min(100%, 42rem);
    text-align: center;
  }

  .events-none {
    pointer-events: none;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.5rem, 9vw, 6rem);
    font-weight: 300;
    line-height: 0.95;
  }

  p {
    max-width: 38rem;
    margin: 1rem auto 0;
    font-size: clamp(0.75rem, 1.2vw, 0.95rem);
    line-height: 1.45;
    opacity: 0.72;
  }

  @media (max-width: 640px) {
    .hero {
      padding: max(0.5rem, env(safe-area-inset-top))
        max(0.5rem, env(safe-area-inset-right))
        max(0.5rem, env(safe-area-inset-bottom))
        max(0.5rem, env(safe-area-inset-left));
    }

    .panel {
      width: 100%;
      height: 100%;
      border-radius: 1.25rem;
      padding-top: calc(var(--nav-size-sm) + 3rem);
      padding-bottom: calc(4.5rem + env(safe-area-inset-bottom));
      padding-inline: 1.5rem;
    }

    h1 {
      font-size: clamp(3rem, 17vw, 5rem);
    }

    p {
      font-size: 0.78rem;
    }
  }
</style>
