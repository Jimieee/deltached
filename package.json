{
  "name": "deltached-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter docs dev",
    "dev:lib": "pnpm --filter deltached dev",
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter docs build",
    "build:lib": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "version:packages": "changeset version",
    "release:check": "node scripts/check-release.mjs && pnpm build:lib && pnpm typecheck",
    "release": "pnpm release:check && changeset publish",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,md}\"",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-vue": "^6.0.0",
    "gsap": "^3.15.0",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svelte": "^5.29.0",
    "vite": "^8.0.16",
    "vue": "^3.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"],
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  }
}
