{
  "name": "deltached",
  "version": "0.1.1",
  "description": "An interruptible shared-element morph controller for the web.",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "animation",
    "gsap",
    "morph",
    "shared-element",
    "transition"
  ],
  "homepage": "https://jimieee.github.io/deltached/",
  "bugs": {
    "url": "https://github.com/Jimieee/deltached/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jimieee/deltached.git",
    "directory": "packages/deltached"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm typecheck"
  },
  "peerDependencies": {
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "gsap": "^3.15.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
